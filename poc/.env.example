# Copy this file to `.env` (or export the variable in your shell) and add your key.
# Get a free key at https://console.groq.com/keys
# The app and smoke test read GROQ_API_KEY from the environment.
GROQ_API_KEY=

# Optional: override the model. Defaults to llama-3.3-70b-versatile.
# If the 70B model is rate-limited on the free tier, use the lighter fallback:
# GROQ_MODEL=llama-3.1-8b-instant
